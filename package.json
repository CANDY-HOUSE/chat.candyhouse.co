    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "aws-amplify": "^4.3.16",
    "axios": "^1.8.2",
    "hotkeys-js": "^4.0.0-beta.7",
    "i18next": "^23.15.1",
    "jotai": "^2.9.3",
    "json5": "^2.2.3",
    "localforage": "^1.10.0",
    "lodash-es": "^4.17.21",
    "loglevel": "^1.9.2",
    "motion": "^12.23.12",
    "quill": "^2.0.3",
    "quill-delta-to-html": "^0.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~15.0.1",
    "react-markdown": "^9.0.1",
    "react-photo-view": "^1.2.7",
